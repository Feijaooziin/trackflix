{
  "expo": {
    "name": "TrackFlix",
    "slug": "trackflix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/adaptive-icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050406"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#050406",
        "foregroundImage": "./src/assets/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.feijaoozin.trackflix"
    },
    "web": {
      "favicon": ""
    },
    "plugins": ["expo-sqlite"],
    "extra": {
      "eas": {
        "projectId": "2e26a8d6-165e-4b4f-8051-05a44a8f424b"
      }
    }
  }
}
